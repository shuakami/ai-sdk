{
  "name": "@sdjz/ai-sdk",
  "version": "0.1.0",
  "description": "Lightweight AI SDK with agent loop, tools, middleware, and provider orchestration.",
  "type": "module",
  "main": "./index.js",
  "types": "./index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./index.js"
    },
