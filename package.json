      "types": "./types.d.ts",
      "import": "./types.js"
    },
    "./testing": {
      "types": "./testing.d.ts",
      "import": "./testing.js"
    }
  },
  "files": [
    "index.js",
    "index.d.ts",
    "types.js",
    "types.d.ts",
    "testing.js",
    "testing.d.ts",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "ai",
    "sdk",
    "agent",
    "tool-calling",
    "llm"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shuakami/ai-sdk.git"
  },
  "bugs": {
